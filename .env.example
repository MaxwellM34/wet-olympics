# Copy to .env.local for dev. Set the same vars in Vercel for prod.

# Postgres connection. Vercel-Postgres / Neon / etc all work.
# For the Wet Party Hostel VPS option: postgres://USER:PASS@188.245.197.63:5432/wet_olympics?sslmode=require
DATABASE_URL=postgres://user:pass@host:5432/wet_olympics?sslmode=require

# Admin login (single user/pass). Anyone with these can edit teams + brackets.
ADMIN_USER=admin
ADMIN_PASS=changeme

# Used to sign the admin session cookie. Generate: openssl rand -base64 32
ADMIN_JWT_SECRET=replace-me-with-random-string

# Token required to call POST /api/init-db (one-time DB bootstrap).
# Generate: openssl rand -hex 16
INIT_TOKEN=replace-me-with-random-string
